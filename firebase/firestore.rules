rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 사용자 데이터: 본인만 읽기/쓰기 가능 ──
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── 마굿간: 본인만 접근 ──
    match /stables/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /stables/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── 쿠폰: 읽기만 허용 / 쓰기는 Cloud Function 또는 트랜잭션 ──
    match /coupons/{couponId} {
      // 로그인한 사용자는 쿠폰 조회 가능
      allow read: if request.auth != null;
      // 클라이언트 직접 쓰기: usedCount, usedBy, usedAt, status 필드만 허용 (트랜잭션용)
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['usedCount', 'usedBy', 'usedAt', 'status']);
      // 신규 생성 및 삭제는 금지 (관리자 콘솔에서만)
      allow create, delete: if false;
    }

    // ── 쿠폰 사용 내역: 본인 기록만 생성/조회 가능 ──
    match /couponUsages/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── IP 계정 관리: 인증된 사용자만 ──
    match /ipAccounts/{ip} {
      allow read, write: if request.auth != null;
    }

    // ── NFT collectionGroup 쿼리를 위한 규칙 ──
    // users/{uid}/nfts 서브컬렉션은 users/{uid} 규칙에 포함됨
    // collectionGroup('nfts') 조회는 인증된 사용자 허용
    match /{path=**}/nfts/{nftId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == resource.data.ownerId;
    }

    // ── 기본: 나머지 모든 경로 차단 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
