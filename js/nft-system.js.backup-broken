    return;
  }

  container.innerHTML = nfts.map(nft => {
    const maxAmount = Math.floor(nft.rarity.priceRange[1] * 0.9);
    return `
      <div class="row" style="background:#1a1a2e;padding:10px;margin:5px 0;border-radius:6px;align-items:center;">
        <img src="${nft.imageUrl}" style="width:50px;height:50px;border-radius:4px;">
