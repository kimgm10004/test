// 전역 함수들
function selectNFTForRace(nftId) {
  const nft = nftSystem.selectNFTForRace(nftId);
  if (nft) {
    alert(`${nft.name} 말 선택 완료!\n경주 시 스탯이 버프됩니다.`);
  }
}

function generateExchangeCode(nftId) {
  const result = nftSystem.setExchangeCode(nftId);
  if (result.success) {
    alert(`교환 코드: ${result.code}\n이 코드를 다른 사용자에게 전달하세요.\n(클립보드에 복사됨)`);
  }
}

function showNFTSellModal(nftId) {
  const nft = nftSystem.myNFTs.find(n => n.id === nftId);
  if (!nft) return;

  const price = prompt(`판매 가격을 입력하세요 (${nft.rarity.priceRange[0].toLocaleString()} - ${nft.rarity.priceRange[1].toLocaleString()}원):`, nft.rarity.priceRange[0]);
  
  if (price) {
    const result = nftSystem.listNFT(nftId, parseInt(price));
    alert(result.message);
    renderNFTInventory();
  }
}

function buyFromMarketplace(nftId) {
  const result = nftSystem.buyFromMarketplace(nftId);
  alert(result.message);
  if (result.success) {
    renderNFTMarketplace();
    renderNFTInventory();
  }
}

function showNFTConvertModal(nftId) {
  const nft = nftSystem.myNFTs.find(n => n.id === nftId);
  if (!nft) return;

  const maxAmount = Math.floor(nft.rarity.priceRange[1] * 0.9);
  const price = prompt(`전환할 금액을 입력하세요 (최대 ${maxAmount.toLocaleString()}원, 10% 수수료 적용):`, Math.floor(maxAmount * 0.5));
  
  if (price) {
    const result = nftSystem.convertToBettingAmount(nftId, parseInt(price));
    alert(result.message);
    if (result.success) {
      renderNFTInventory();
    }
  }
}

