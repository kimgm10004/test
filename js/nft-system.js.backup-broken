// 교환 코드 사용
function redeemExchangeCode() {
  const code = document.getElementById('exchangeCodeInput').value.trim();
  if (!code) {
    alert('교환 코드를 입력하세요');
    return;
  }

  if (nftSystem) {
    nftSystem.receiveViaExchangeCode(code).then(result => {
      alert(result.message);
      if (result.success) {
        renderNFTInventory();
        document.getElementById('exchangeCodeInput').value = '';
      }
    });
  }
}

// 베팅 시 NFT 말 선택
function showNFTSelectForBetting() {
  if (!nftSystem || nftSystem.myNFTs.filter(n => n.type === 'HORSE').length === 0) {
    alert('보유한 NFT 말이 없습니다.\nNFT 탭에서 구매하세요!');
    return;
  }

  let html = '<div style="max-height:300px;overflow-y:auto;">';
  nftSystem.myNFTs.filter(n => n.type === 'HORSE').forEach(nft => {
    const isSelected = window.selectedNFTForRace && window.selectedNFTForRace.id === nft.id;
    html += `
      <div style="background:${isSelected ? '#2ecc71' : '#1a1a2e'};padding:10px;margin:5px 0;border-radius:6px;cursor:pointer;" onclick="selectNFTForRace('${nft.id}')">
        <div style="display:flex;align-items:center;">
          <img src="${nft.imageUrl}" style="width:40px;height:40px;border-radius:4px;">
          <div style="flex:1;margin-left:10px;">
            <div><strong>${nft.name}</strong> [${nft.rarity.name}]</div>
            <div style="font-size:10px;color:#888;">속:${nft.stats.speed} 지구:${nft.stats.stamina} 스퍼트:${nft.stats.burst}</div>
          </div>
          ${isSelected ? '<span style="color:#fff;">✓ 선택됨</span>' : ''}
        </div>
      </div>
    `;
  });
  html += '</div>';
  html += '<div style="margin-top:10px;"><button onclick="clearSelectedNFT()" style="background:#e74c3c;">선택 해제</button></div>';

  const modal = document.createElement('div');
  modal.id = 'nftSelectModal';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,20,.9);display:flex;align-items:center;justify-content:center;z-index:99999;';
  modal.innerHTML = `
    <div style="background:#0f1424;border:1px solid #333;border-radius:12px;padding:20px;max-width:400px;width:90%;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
        <h3 style="margin:0;">🐴 경주용 NFT 말 선택</h3>
        <button onclick="document.getElementById('nftSelectModal').remove()" style="background:transparent;border:1px solid #666;">✕</button>
      </div>
      ${html}
    </div>
  `;
  document.body.appendChild(modal);
}

function clearSelectedNFT() {
  window.selectedNFTForRace = null;
  alert('NFT 말 선택이 해제되었습니다');
  const modal = document.getElementById('nftSelectModal');
  if (modal) modal.remove();
}

