/**
 * NFT Horse System v1.0
 * 도트경마 v5.2 - NFT 말 시스템
 */

const NFT_RARITIES = {
  COMMON: { name: '일반', probability: 0.60, purchasePrice: 10000, priceRange: [8000, 20000], statRange: [40, 60] },
  RARE: { name: '레어', probability: 0.25, purchasePrice: 50000, priceRange: [40000, 100000], statRange: [60, 75] },
  EPIC: { name: '에픽', probability: 0.10, purchasePrice: 200000, priceRange: [150000, 400000], statRange: [75, 85] },
  LEGENDARY: { name: '전설', probability: 0.05, purchasePrice: 1000000, priceRange: [800000, 2000000], statRange: [85, 100] }
};

const NFT_HORSE_NAMES = ['불꽃질주', '천둥이', '황금빛', '달빛', '폭풍', '무적의', ' سريع', '왕중왕', '미친', '초고속', '태풍', '벼락', '화살', '광속', '瞬步', '黑豹', '白馬', '赤兔', '驃騎', '天馬'];
const NFT_JOCKEY_NAMES = ['김骑수', '이ライダー', '박건마', '최명骑', '정스킬', '한빠름', '오마', '신천재', '류마스터', '장传奇'];

class NFTSystem {
  constructor() {
    this.myNFTs = [];
    this.marketplaceNFTs = [];
    this.loadFromLocalStorage();
  }

  checkFirebaseReady() {
    return window.db && window.uid;
  }

  saveToLocalStorage() {
    try {
      localStorage.setItem('myNFTs', JSON.stringify(this.myNFTs));
    } catch (err) {
      console.error('[NFT] localStorage 저장 실패:', err);
    }
  }

  loadFromLocalStorage() {
    try {
      const stored = localStorage.getItem('myNFTs');
      if (stored) this.myNFTs = JSON.parse(stored);
    } catch (err) {
      this.myNFTs = [];
    }
  }

  getRandomRarity() {
    const rand = Math.random();
    let cumulative = 0;
    for (const [key, rarity] of Object.entries(NFT_RARITIES)) {
      cumulative += rarity.probability;
      if (rand < cumulative) return { key, ...rarity };
    }
    return { key: 'COMMON', ...NFT_RARITIES.COMMON };
  }

  getRandomHorseName() {
    return NFT_HORSE_NAMES[Math.floor(Math.random() * NFT_HORSE_NAMES.length)];
  }

  getRandomJockeyName() {
    return NFT_JOCKEY_NAMES[Math.floor(Math.random() * NFT_JOCKEY_NAMES.length)];
  }

  getRandomStats(rarity) {
    const [min, max] = rarity.statRange;
    return {
      speed: Math.floor(Math.random() * (max - min + 1)) + min,
      stamina: Math.floor(Math.random() * (max - min + 1)) + min,
      burst: Math.floor(Math.random() * (max - min + 1)) + min
    };
  }

  async createNFT(type = 'HORSE', rarity = null) {
    const nft = {
      id: 'nft_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6),
      type: type,
      name: type === 'HORSE' ? this.getRandomHorseName() : this.getRandomJockeyName(),
      rarity: rarity || this.getRandomRarity(),
      createdAt: Date.now(),
      ownerId: window.uid || 'anonymous',
      isListed: false,
      listedPrice: 0,
      exchangeCode: null,
      previousOwners: [window.uid || 'anonymous']
    };
    if (type === 'HORSE') nft.stats = this.getRandomStats(nft.rarity);
    nft.imageUrl = await this.generateNFTImage(nft);
    return nft;
  }

  async generateNFTImage(nft) {
    return new Promise(resolve => {
      const canvas = document.createElement('canvas');
      canvas.width = 200; canvas.height = 200;
      const ctx = canvas.getContext('2d');
      const gradient = ctx.createLinearGradient(0, 0, 200, 200);
      const colors = { LEGENDARY: ['#FFD700', '#FF6B00'], EPIC: ['#9B59B6', '#E74C3C'], RARE: ['#3498DB', '#2ECC71'], COMMON: ['#95A5A6', '#7F8C8D'] };
      const color = colors[nft.rarity.key] || colors.COMMON;
      gradient.addColorStop(0, color[0]); gradient.addColorStop(1, color[1]);
      ctx.fillStyle = gradient; ctx.fillRect(0, 0, 200, 200);
      ctx.font = '80px Arial'; ctx.textAlign = 'center'; ctx.fillText(nft.type === 'HORSE' ? '🐴' : '🏇', 100, 110);
      ctx.font = 'bold 20px Arial'; ctx.fillStyle = '#FFFFFF'; ctx.fillText(nft.name, 100, 150);
      ctx.font = 'bold 14px Arial'; ctx.fillText(nft.rarity.key === 'LEGENDARY' ? '★전설' : nft.rarity.key === 'EPIC' ? '♦에픽' : nft.rarity.key === 'RARE' ? '★레어' : '일반', 100, 180);
      resolve(canvas.toDataURL('image/png'));
    });
  }

  async saveNFTToFirestore(nft) {
    this.myNFTs.push(nft);
    this.saveToLocalStorage();
    if (!this.checkFirebaseReady()) return nft;
    try {
      const userRef = window.db.collection('users').doc(window.uid).collection('nfts').doc(nft.id);
      await userRef.set({ ...nft, createdAt: window.firebase.firestore.FieldValue.serverTimestamp() });
    } catch (err) {
      console.error('[NFT] 저장 실패:', err);
    }
    return nft;
  }

  async loadNFTsFromFirestore() {
    if (!this.checkFirebaseReady()) return this.myNFTs;
    try {
      const snapshot = await window.db.collection('users').doc(window.uid).collection('nfts').get();
      this.myNFTs = [];
      snapshot.forEach(doc => this.myNFTs.push({ id: doc.id, ...doc.data() }));
    } catch (err) {
      console.error('[NFT] 로드 실패:', err);
    }
    return this.myNFTs;
  }

  async loadMarketplaceNFTs() {
    if (!this.checkFirebaseReady()) return [];
    try {
      const snapshot = await window.db.collectionGroup('nfts').where('isListed', '==', true).get();
      this.marketplaceNFTs = [];
      snapshot.forEach(doc => {
        const nft = { id: doc.id, ...doc.data() };
        if (nft.ownerId !== window.uid) this.marketplaceNFTs.push(nft);
      });
    } catch (err) {
      console.error('[NFT Market] 로드 실패:', err);
    }
    return this.marketplaceNFTs;
  }

  async listNFT(nftId, price) {
    const nft = this.myNFTs.find(n => n.id === nftId);
    if (!nft) return { success: false };
    nft.isListed = true; nft.listedPrice = price;
    this.saveToLocalStorage();
    if (this.checkFirebaseReady()) {
      try {
        await window.db.collection('users').doc(window.uid).collection('nfts').doc(nftId).update({ isListed: true, listedPrice: price });
      } catch (err) { console.error('[NFT] 판매 등록 실패:', err); }
    }
    return { success: true };
  }

  selectNFTForRace(nftId) {
    const nft = this.myNFTs.find(n => n.id === nftId);
    if (!nft || nft.type !== 'HORSE') return null;
    window.selectedNFTForRace = nft;
    return nft;
  }

  getNFTBuff() {
    if (!window.selectedNFTForRace) return { speed: 0, stamina: 0, burst: 0 };
    const nft = window.selectedNFTForRace;
    const buffRatio = { COMMON: 0.05, RARE: 0.08, EPIC: 0.12, LEGENDARY: 0.20 };
    const ratio = buffRatio[nft.rarity.key] || 0.05;
    return {
      speed: Math.floor(nft.stats.speed * ratio),
      stamina: Math.floor(nft.stats.stamina * ratio),
      burst: Math.floor(nft.stats.burst * ratio)
    };
  }

  generateExchangeCode(nftId) {
    return 'EXCHANGE-' + nftId + '-' + Math.random().toString(36).substr(2, 6).toUpperCase();
  }

  async setExchangeCode(nftId) {
    const nft = this.myNFTs.find(n => n.id === nftId);
    if (!nft) return { success: false };
    const code = this.generateExchangeCode(nftId);
    nft.exchangeCode = code;
    this.saveToLocalStorage();
    if (this.checkFirebaseReady()) {
      try {
        await window.db.collection('users').doc(window.uid).collection('nfts').doc(nftId).update({ exchangeCode: code });
      } catch (err) { console.error('[NFT] 교환 코드 설정 실패:', err); }
    }
    if (navigator.clipboard) navigator.clipboard.writeText(code);
    return { success: true, code };
  }
}

let nftSystem = null;

async function initNFTSystem() {
  // 이미 초기화됨
  if (nftSystem) {
    console.log('[NFT] 이미 초기화됨, 렌더링만 수행');
    renderNFTInventory();
    renderNFTMarketplace();
    renderNFTConvertList();
    return nftSystem;
  }
  
  nftSystem = new NFTSystem();
  console.log('[NFT System v1.0] 초기화 완료');
  
  // localStorage에서 먼저 로드
  nftSystem.loadFromLocalStorage();
  renderNFTInventory();
  
  // Firebase 대기
  let retries = 0;
  while (!window.db && retries < 20) {
    await new Promise(resolve => setTimeout(resolve, 500));
    retries++;
  }
  if (window.db && window.uid) {
    try {
      await nftSystem.loadNFTsFromFirestore();
      await nftSystem.loadMarketplaceNFTs();
      renderNFTInventory();
      renderNFTMarketplace();
      renderNFTConvertList();
    } catch (err) {
      console.log('[NFT] Firebase 로드 실패, localStorage 사용');
    }
  }
  return nftSystem;
}

function renderNFTInventory() {
  const container = document.getElementById('nftInventory');
  if (!container) {
    console.log('[NFT] 보관함 컨테이너 없음');
    return;
  }
  
  // nftSystem이 없으면 초기화 시도
  if (!nftSystem) {
    container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;">NFT 시스템 로딩 중...</div>';
    initNFTSystem();
    return;
  }
  
  const nfts = nftSystem.myNFTs || [];
  if (nfts.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;">보유한 NFT가 없습니다<br><br><button onclick="showNFTCreateModal()" style="background:#9b59b6;padding:10px 20px;border-radius:8px;">구매하기</button></div>';
    return;
  }
  container.innerHTML = nfts.map(nft => `
    <div class="nft-card" style="background:#1a1a2e;border:1px solid #333;border-radius:8px;padding:10px;margin:5px;">
      <img src="${nft.imageUrl}" style="width:100%;border-radius:4px;">
      <div style="font-size:12px;margin-top:5px;">
        <strong>${nft.name}</strong>
        <span style="color:${nft.rarity.key === 'LEGENDARY' ? '#FFD700' : nft.rarity.key === 'EPIC' ? '#9B59B6' : nft.rarity.key === 'RARE' ? '#3498DB' : '#95A5A6'}">[${nft.rarity.name}]</span>
      </div>
      ${nft.type === 'HORSE' && nft.stats ? `<div style="font-size:10px;color:#888;margin-top:3px;">속:${nft.stats.speed} 지구:${nft.stats.stamina} 스퍼트:${nft.stats.burst}</div>` : ''}
      <div style="display:flex;gap:5px;margin-top:8px;">
        ${nft.type === 'HORSE' ? `<button onclick="selectNFTForRace('${nft.id}')" style="flex:1;background:#27ae60;">사용</button>` : ''}
        <button onclick="showNFTSellModal('${nft.id}')" style="flex:1;background:#e67e22;">판매</button>
        <button onclick="generateExchangeCode('${nft.id}')" style="flex:1;background:#9b59b6;">교환</button>
      </div>
    </div>
  `).join('');
}

function renderNFTMarketplace() {
  const container = document.getElementById('nftMarketplace');
  if (!container) return;
  
  if (!nftSystem) {
    container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;">마켓 로딩 중...</div>';
    return;
  }
  
  const nfts = nftSystem.marketplaceNFTs || [];
  if (nfts.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;">마켓플레이스에 등록된 NFT가 없습니다</div>';
    return;
  }
  container.innerHTML = nfts.map(nft => `
    <div class="nft-card" style="background:#1a1a2e;border:1px solid #333;border-radius:8px;padding:10px;margin:5px;">
      <img src="${nft.imageUrl}" style="width:100%;border-radius:4px;">
      <div style="font-size:12px;margin-top:5px;"><strong>${nft.name}</strong> <span style="color:${nft.rarity.key === 'LEGENDARY' ? '#FFD700' : nft.rarity.key === 'EPIC' ? '#9B59B6' : nft.rarity.key === 'RARE' ? '#3498DB' : '#95A5A6'}">[${nft.rarity.name}]</span></div>
      <div style="font-size:14px;color:#ffd700;margin-top:5px;">${nft.listedPrice.toLocaleString()}원</div>
      <button onclick="buyFromMarketplace('${nft.id}')" style="width:100%;margin-top:8px;background:#e74c3c;">구매하기</button>
    </div>
  `).join('');
}

function renderNFTConvertList() {
  const container = document.getElementById('nftConvertList');
  if (!container) return;
  
  if (!nftSystem) {
    container.innerHTML = '<div style="text-align:center;padding:20px;color:#888;">로딩 중...</div>';
    return;
  }
  
  const nfts = (nftSystem.myNFTs || []).filter(n => n.type === 'HORSE');
  if (nfts.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:20px;color:#888;">전환할 NFT가 없습니다</div>';
    return;
  }
  container.innerHTML = nfts.map(nft => {
    const maxAmount = Math.floor(nft.rarity.priceRange[1] * 0.9);
    return `<div class="row" style="background:#1a1a2e;padding:10px;margin:5px 0;border-radius:6px;align-items:center;">
      <img src="${nft.imageUrl}" style="width:50px;height:50px;border-radius:4px;">
      <div style="flex:1;margin-left:10px;"><div><strong>${nft.name}</strong> [${nft.rarity.name}]</div><div style="font-size:11px;color:#888;">최대 전환: ${maxAmount.toLocaleString()}원</div></div>
      <button onclick="showNFTConvertModal('${nft.id}')" style="background:#e74c3c;">전환</button>
    </div>`;
  }).join('');
}

function selectNFTForRace(nftId) {
  const nft = nftSystem.selectNFTForRace(nftId);
  if (nft) alert(`${nft.name} 말 선택 완료!`);
}

function generateExchangeCode(nftId) {
  const result = nftSystem.setExchangeCode(nftId);
  if (result.success) alert(`교환 코드: ${result.code}\n클립보드에 복사됨`);
}

function showNFTSellModal(nftId) {
  const nft = nftSystem.myNFTs.find(n => n.id === nftId);
  if (!nft) return;
  const price = prompt(`판매 가격 (${nft.rarity.priceRange[0].toLocaleString()} - ${nft.rarity.priceRange[1].toLocaleString()}원):`, nft.rarity.priceRange[0]);
  if (price) {
    nftSystem.listNFT(nftId, parseInt(price));
    alert('판매 등록됨');
    renderNFTInventory();
  }
}

function buyFromMarketplace(nftId) {
  alert('마켓플레이스 구매 기능은 준비중입니다');
}

function showNFTConvertModal(nftId) {
  const nft = nftSystem.myNFTs.find(n => n.id === nftId);
  if (!nft) return;
  const maxAmount = Math.floor(nft.rarity.priceRange[1] * 0.9);
  const amount = prompt(`전환 금액 (최대 ${maxAmount.toLocaleString()}원, 10% 수수료):`, Math.floor(maxAmount * 0.5));
  if (amount) {
    const fee = Math.floor(amount * 0.1);
    const actual = amount - fee;
    window.wallet += actual;
    document.getElementById('wallet').textContent = window.fmt(window.wallet);
    nftSystem.myNFTs = nftSystem.myNFTs.filter(n => n.id !== nftId);
    nftSystem.saveToLocalStorage();
    alert(`${actual.toLocaleString()}원 추가 (수수료: ${fee.toLocaleString()}원)`);
    renderNFTInventory();
  }
}

function showNFTCreateModal() {
  const choice = confirm('NFT 말을 구매하시겠습니까?\n\n가격: 10,000원 ~ 1,000,000원');
  if (!choice) return;
  const price = prompt('가격 선택:\n1. 일반 (10,000원)\n2. 레어 (50,000원)\n3. 에픽 (200,000원)\n4. 전설 (1,000,000원)\n5. 랜덤', '5');
  let rarity = null;
  if (price === '1') rarity = { key: 'COMMON', ...NFT_RARITIES.COMMON, purchasePrice: 10000 };
  else if (price === '2') rarity = { key: 'RARE', ...NFT_RARITIES.RARE, purchasePrice: 50000 };
  else if (price === '3') rarity = { key: 'EPIC', ...NFT_RARITIES.EPIC, purchasePrice: 200000 };
  else if (price === '4') rarity = { key: 'LEGENDARY', ...NFT_RARITIES.LEGENDARY, purchasePrice: 1000000 };
  const purchasePrice = rarity ? rarity.purchasePrice : NFT_RARITIES.COMMON.purchasePrice;
  if (window.wallet < purchasePrice) { alert('잔액 부족!'); return; }
  window.wallet -= purchasePrice;
  document.getElementById('wallet').textContent = window.fmt(window.wallet);
  nftSystem.createNFT('HORSE', rarity).then(nft => {
    nft.purchasePrice = purchasePrice;
    nftSystem.saveNFTToFirestore(nft);
    alert(`${nft.name} (${nft.rarity.name}) 구매 완료!`);
    renderNFTInventory();
  });
}

function showNFTSelectForBetting() {
  if (!nftSystem || nftSystem.myNFTs.filter(n => n.type === 'HORSE').length === 0) { alert('보유한 NFT 말이 없습니다!'); return; }
  let html = '<div style="max-height:300px;overflow-y:auto;">';
  nftSystem.myNFTs.filter(n => n.type === 'HORSE').forEach(nft => {
    const isSelected = window.selectedNFTForRace && window.selectedNFTForRace.id === nft.id;
    html += `<div style="background:${isSelected ? '#2ecc71' : '#1a1a2e'};padding:10px;margin:5px 0;border-radius:6px;cursor:pointer;" onclick="selectNFTForRace('${nft.id}')">
      <div style="display:flex;align-items:center;"><img src="${nft.imageUrl}" style="width:40px;height:40px;border-radius:4px;">
        <div style="flex:1;margin-left:10px;"><div><strong>${nft.name}</strong> [${nft.rarity.name}]</div><div style="font-size:10px;color:#888;">속:${nft.stats.speed} 지구:${nft.stats.stamina} 스퍼트:${nft.stats.burst}</div></div>
        ${isSelected ? '<span style="color:#fff;">✓</span>' : ''}</div></div>`;
  });
  html += '</div><div style="margin-top:10px;"><button onclick="window.selectedNFTForRace=null;document.getElementById(\'nftSelectModal\').remove()" style="background:#e74c3c;">선택 해제</button></div>';
  const modal = document.createElement('div');
  modal.id = 'nftSelectModal';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,20,.9);display:flex;align-items:center;justify-content:center;z-index:99999;';
  modal.innerHTML = `<div style="background:#0f1424;border:1px solid #333;border-radius:12px;padding:20px;max-width:400px;width:90%;"><div style="display:flex;justify-content:space-between;margin-bottom:15px;"><h3 style="margin:0;">🐴 NFT 말 선택</h3><button onclick="this.closest('#nftSelectModal').remove()" style="background:transparent;border:1px solid #666;">✕</button></div>${html}</div>`;
  document.body.appendChild(modal);
}

function redeemExchangeCode() {
  const code = document.getElementById('exchangeCodeInput').value.trim();
  if (!code) { alert('교환 코드를 입력하세요'); return; }
  alert('교환 코드 사용 기능은 준비중입니다');
}

